#include <Wire.h>
#include <SPI.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET    -1
#define MPU_ADDR      0x68
#define MOTION_THRESHOLD 1000

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// Previous acceleration values
int16_t prevAcX = 0, prevAcY = 0, prevAcZ = 0;

void setup() {
  Wire.begin();
  Serial.begin(9600);

  // Initialize MPU6050
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x6B);  // Power management register
  Wire.write(0);     // Wake up MPU6050
  Wire.endTransmission(true);

  // Initialize OLED
  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("SSD1306 allocation failed"));
    while (true); // halt
  }

  display.clearDisplay();
  display.setTextColor(WHITE);
  display.setTextSize(1);
  display.setCursor(10, 20);
  display.print("zintechideas");
  display.display();
  delay(3000);
  display.clearDisplay();
}

void loop() {
  // Read accelerometer data
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x3B);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU_ADDR, 6, true);  // Only read AcX, AcY, AcZ

  int16_t AcX = Wire.read() << 8 | Wire.read();
  int16_t AcY = Wire.read() << 8 | Wire.read();
  int16_t AcZ = Wire.read() << 8 | Wire.read();

  // Calculate delta (change)
  int16_t dX = AcX - prevAcX;
  int16_t dY = AcY - prevAcY;
  int16_t dZ = AcZ - prevAcZ;

  // Store current values for next iteration
  prevAcX = AcX;
  prevAcY = AcY;
  prevAcZ = AcZ;

  // Determine direction
  String direction = "Stable";
  int maxChange = max(max(abs(dX), abs(dY)), abs(dZ));

  if (maxChange > MOTION_THRESHOLD) {
    if (abs(dX) == maxChange)
      direction = (dX > 0) ? "Right" : "Left";
    else if (abs(dY) == maxChange)
      direction = (dY > 0) ? "Forward" : "Backward";
    else
      direction = (dZ > 0) ? "Up" : "Down";
  }

  // Debug log
  Serial.print("AcX: "); Serial.print(AcX);
  Serial.print(" | AcY: "); Serial.print(AcY);
  Serial.print(" | AcZ: "); Serial.print(AcZ);
  Serial.print(" | Direction: "); Serial.println(direction);

  // Display motion direction
  display.clearDisplay();
  display.setTextSize(2);
  display.setCursor(10, 25);
  display.print(direction);
  display.display();

  delay(200);
}





