// MPU6050 address
const int MPU_addr = 0x68;
int16_t AcX, AcY;


U8G2_SSD1306_128X64_NONAME_F_HW_I2C u8g2(U8G2_R0, /* reset=*/ U8X8_PIN_NONE); // initialization for the used OLED display
unsigned long previousMillis = 0;
const unsigned long interval = 5000;  // Time between actions in ms

int repeatCount = 0;          // How many times to repeat current function
int currentFunction = -1;     // The function currently being repeated



int i;
int till;
void happy(){
  till = happyallArray_LEN;
  for(i=0;i<=till;i++){
    u8g2.clearBuffer();					// clear the internal memory
    u8g2.drawXBMP(0, 0, 128, 64, happyallArray[i]); // draw fullscreen image generated by image2cpp website
    u8g2.sendBuffer();					// transfer internal memory to the display
  }
}

